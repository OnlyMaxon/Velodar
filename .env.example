# Copy to .env and fill in. Do NOT commit .env.
#
# EXPO_PUBLIC_* vars are inlined into the JS bundle and readable from process.env
# in app code. The Supabase anon key is safe to ship (it's public by design;
# security is enforced by Row Level Security). Never put a service_role key here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Google Maps SDK key for Android (react-native-maps requires it on Android).
# Restrict the key to the Android app (package name + SHA-1) in Google Cloud.
# Not needed for iOS (uses Apple Maps).
GOOGLE_MAPS_ANDROID_API_KEY=YOUR-ANDROID-MAPS-KEY
